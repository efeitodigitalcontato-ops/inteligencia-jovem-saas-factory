---
// ComparisonTable.astro
interface Product {
  id?: string;
  title: string;
  image: string;
  rating: number;
  reviewsCount: string;
  amazonLink: string; // Will map to CTA
  priceEstimate: string;
  specs?: string[];
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;

// Filter top products for comparison (max 3 or 4)
const topProducts = products.slice(0, 3);

// Badges helper
const getBadge = (index: number) => {
  if (index === 0) return { text: "🏆 ESCOLHA DO EDITOR", class: "badge-editor" };
  if (index === 1) return { text: "⭐ MELHOR CUSTO-BENEFÍCIO", class: "badge-value" };
  return { text: "💎 PREFERÊNCIA PREMIUM", class: "badge-premium" };
};
---

{topProducts.length > 0 && (
  <div class="comparison-container">
    <h3 class="comparison-header-title">⚡ Tabela Comparativa dos Melhores Modelos</h3>
    
    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Modelo</th>
            {topProducts.map((prod, idx) => (
              <th>
                <div class="badge-wrapper">
                  <span class={`comparison-badge ${getBadge(idx).class}`}>{getBadge(idx).text}</span>
                </div>
                <div class="product-th-info">
                  <span class="product-name-th">{prod.title}</span>
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          <!-- Imagem -->
          <tr>
            <td class="row-label">Visual</td>
            {topProducts.map(prod => (
              <td>
                <div class="table-img-container">
                  <img src={prod.image} alt={prod.title} loading="lazy" width="90" height="90" decoding="async" />
                </div>
              </td>
            ))}
          </tr>
          <!-- Avaliação -->
          <tr>
            <td class="row-label">Avaliação</td>
            {topProducts.map(prod => (
              <td>
                <div class="rating-cell">
                  <span class="rating-stars">{"★".repeat(Math.floor(prod.rating))}</span>
                  <span class="rating-number"><strong>{prod.rating}</strong> ({prod.reviewsCount})</span>
                </div>
              </td>
            ))}
          </tr>
          <!-- Preço -->
          <tr>
            <td class="row-label">Estimativa</td>
            {topProducts.map(prod => (
              <td>
                <span class="price-cell">{prod.priceEstimate}</span>
              </td>
            ))}
          </tr>
          <!-- Especificações chave -->
          <tr>
            <td class="row-label">Ficha Técnica</td>
            {topProducts.map(prod => (
              <td>
                <ul class="table-specs-list">
                  {(prod.specs || []).slice(0, 3).map(spec => (
                    <li>&bull; {spec}</li>
                  ))}
                </ul>
              </td>
            ))}
          </tr>
          <!-- Link / CTA -->
          <tr>
            <td class="row-label">Oferta</td>
            {topProducts.map(prod => (
              <td>
                <a href={prod.amazonLink} target="_blank" rel="noopener noreferrer nofollow" class="table-cta-btn">
                  Ver Menor Preço
                </a>
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </div>
)}

<style>
  .comparison-container {
    background: #ffffff;
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin: 2rem 0;
    box-shadow: var(--shadow-subtle, 0 1px 3px 0 rgba(0, 0, 0, 0.05));
  }

  .comparison-header-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
    border-radius: 0.5rem;
    border: 1px solid #f1f5f9;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
    font-size: 0.9rem;
    min-width: 600px;
  }

  .comparison-table th, .comparison-table td {
    padding: 1rem;
    border: 1px solid #f1f5f9;
  }

  .comparison-table th {
    background-color: #f8fafc;
    vertical-align: top;
    font-weight: 700;
  }

  .row-label {
    font-weight: 700;
    background-color: #f8fafc;
    color: #475569;
    text-align: left;
    width: 120px;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-wrapper {
    margin-bottom: 0.75rem;
    height: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .comparison-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .badge-editor {
    background-color: #fef3c7;
    color: #d97706;
  }

  .badge-value {
    background-color: #dcfce7;
    color: #15803d;
  }

  .badge-premium {
    background-color: #e0f2fe;
    color: #0369a1;
  }

  .product-name-th {
    font-size: 0.95rem;
    color: #1e293b;
    display: block;
    line-height: 1.4;
  }

  .table-img-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.25rem;
  }

  .table-img-container img {
    max-width: 90px;
    max-height: 90px;
    object-fit: contain;
  }

  .rating-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .rating-stars {
    color: #eab308;
    font-size: 1.1rem;
  }

  .rating-number {
    font-size: 0.75rem;
    color: #64748b;
  }

  .price-cell {
    font-weight: 700;
    color: #0f172a;
    font-size: 0.95rem;
  }

  .table-specs-list {
    list-style: none;
    padding-left: 0;
    text-align: left;
    margin: 0 auto;
    max-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .table-specs-list li {
    font-size: 0.75rem;
    color: #475569;
    line-height: 1.3;
  }

  .table-cta-btn {
    display: inline-block;
    background-color: #f97316;
    color: #ffffff !important;
    text-decoration: none !important;
    font-weight: 700;
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    box-shadow: 0 2px 4px rgba(249, 115, 22, 0.2);
    transition: all 0.2s ease;
  }

  .table-cta-btn:hover {
    background-color: var(--primary-hover, #ea580c);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px rgba(249, 115, 22, 0.3);
  }
</style>
